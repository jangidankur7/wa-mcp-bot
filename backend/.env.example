# MCP Streamable HTTP endpoint (mcp_server default when MCP_TRANSPORT=streamable-http)
MCP_URL=

# Upstream request timeout (seconds)
MCP_TIMEOUT_SECONDS=

# MCP client identity sent in initialize payload
MCP_CLIENT_NAME=
MCP_CLIENT_VERSION=

# Chatbot API passthrough for non-/tool messages
CHATBOT_API_URL=
CHATBOT_TIMEOUT_SECONDS=
CHATBOT_MODEL_PROVIDER=
CHATBOT_MODEL_NAME=
# Optional: auth_token cookie value from chatbot session (needed if /api/chat requires auth/model access)
CHATBOT_AUTH_TOKEN=
CHATBOT_MCP_SERVER_ID=
CHATBOT_MCP_SERVER_NAME=

# Optional: if set, POST /webhook/message requires header X-Webhook-Secret with this value
WEBHOOK_SECRET=